# Supabase (Storage)
SUPABASE_URL=
# New key model: publishable key for client-side use
SUPABASE_PUBLISHABLE_KEY=
# Secret key for server-side use only (never expose to client)
SUPABASE_SECRET_KEY=
SUPABASE_STORAGE_BUCKET=kyc

