# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crash_game

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me

# Payments (placeholder)
